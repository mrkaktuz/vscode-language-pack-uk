<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
  <file original="src/vs/workbench/contrib/searchEditor/browser/searchEditor" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="label.excludes">
        <source xml:lang="en">Search Exclude Patterns</source>
        <target>Шукати виключення шаблонів</target>
      </trans-unit>
      <trans-unit id="label.includes">
        <source xml:lang="en">Search Include Patterns</source>
        <target>Шукати шаблони включення</target>
      </trans-unit>
      <trans-unit id="moreSearch">
        <source xml:lang="en">Toggle Search Details</source>
        <target>Переключити деталі пошуку</target>
      </trans-unit>
      <trans-unit id="runSearch">
        <source xml:lang="en">Run Search</source>
        <target>Запустити пошук</target>
      </trans-unit>
      <trans-unit id="searchEditor">
        <source xml:lang="en">Search</source>
        <target>Пошук</target>
      </trans-unit>
      <trans-unit id="searchResultItem">
        <source xml:lang="en">Matched {0} at {1} in file {2}</source>
        <target>Знайдено {0} в {1} у файлі {2}</target>
      </trans-unit>
      <trans-unit id="searchScope.excludes">
        <source xml:lang="en">files to exclude</source>
        <target>файли для виключення</target>
      </trans-unit>
      <trans-unit id="searchScope.includes">
        <source xml:lang="en">files to include</source>
        <target>файли для включення</target>
      </trans-unit>
      <trans-unit id="textInputBoxBorder">
        <source xml:lang="en">Search editor text input box border.</source>
        <target>Кордон текстового поля вводу редактора пошуку.</target>
      </trans-unit>
    </body>
  </file>
  <file original="src/vs/workbench/contrib/searchEditor/browser/searchEditor.contribution" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="promptOpenWith.searchEditor.displayName">
        <source xml:lang="en">Search Editor</source>
        <target>Редактор пошуку</target>
      </trans-unit>
      <trans-unit id="search">
        <source xml:lang="en">Search Editor</source>
        <target>Редактор пошуку</target>
      </trans-unit>
      <trans-unit id="search.action.focusFilesToExclude">
        <source xml:lang="en">Focus Search Editor Files to Exclude</source>
        <target>Фокус пошуку Редактор файлів для виключення</target>
      </trans-unit>
      <trans-unit id="search.action.focusFilesToInclude">
        <source xml:lang="en">Focus Search Editor Files to Include</source>
        <target>Сфокусуватися на файлах редактора пошуку для включення</target>
      </trans-unit>
      <trans-unit id="search.action.focusQueryEditorWidget">
        <source xml:lang="en">Focus Search Editor Input</source>
        <target>Фокус на редакторі пошуку вводу</target>
      </trans-unit>
      <trans-unit id="search.openNewEditor">
        <source xml:lang="en">Open New Search Editor</source>
        <target>Відкрити новий редактор пошуку</target>
      </trans-unit>
      <trans-unit id="search.openNewEditorToSide">
        <source xml:lang="en">Open New Search Editor to the Side</source>
        <target>Відкрити новий редактор пошуку збоку</target>
      </trans-unit>
      <trans-unit id="search.openNewSearchEditor">
        <source xml:lang="en">New Search Editor</source>
        <target>Новий редактор пошуку</target>
      </trans-unit>
      <trans-unit id="search.openResultsInEditor">
        <source xml:lang="en">Open Results in Editor</source>
        <target>Відкрити результати в редакторі</target>
      </trans-unit>
      <trans-unit id="search.openSearchEditor">
        <source xml:lang="en">Open Search Editor</source>
        <target>Відкрити редактор пошуку</target>
      </trans-unit>
      <trans-unit id="search.rerunSearchInEditor">
        <source xml:lang="en">Search Again</source>
        <target>Шукати знову</target>
      </trans-unit>
      <trans-unit id="search.searchEditor.defaultNumberOfContextLines">
        <source xml:lang="en">The default number of surrounding context lines to use when creating new Search Editors. If using `#search.searchEditor.reusePriorSearchConfiguration#`, this can be set to `null` (empty) to use the prior Search Editor's configuration.</source>
        <target>Типове число рядків оточуючого контексту, які використовуються при створенні нових Редакторів Пошуку. Якщо використовується `#search.searchEditor.reusePriorSearchConfiguration#`, це можна встановити на `null` (порожньо), щоб використовувати конфігурацію попереднього Редактора Пошуку.</target>
      </trans-unit>
      <trans-unit id="search.searchEditor.doubleClickBehaviour">
        <source xml:lang="en">Configure effect of double-clicking a result in a search editor.</source>
        <target>Налаштуйте ефект подвійного клацання на результат у редакторі пошуку.</target>
      </trans-unit>
      <trans-unit id="search.searchEditor.doubleClickBehaviour.goToLocation">
        <source xml:lang="en">Double-clicking opens the result in the active editor group.</source>
        <target>Подвійне клацання відкриває результат у активній групі редактора.</target>
      </trans-unit>
      <trans-unit id="search.searchEditor.doubleClickBehaviour.openLocationToSide">
        <source xml:lang="en">Double-clicking opens the result in the editor group to the side, creating one if it does not yet exist.</source>
        <target>Подвійне клацання відкриває результат у групі редактора збоку, створюючи її, якщо вона ще не існує.</target>
      </trans-unit>
      <trans-unit id="search.searchEditor.doubleClickBehaviour.selectWord">
        <source xml:lang="en">Double-clicking selects the word under the cursor.</source>
        <target>Подвійне клацання вибирає слово під курсором.</target>
      </trans-unit>
      <trans-unit id="search.searchEditor.focusResultsOnSearch">
        <source xml:lang="en">When a search is triggered, focus the Search Editor results instead of the Search Editor input.</source>
        <target>Коли ініціюється пошук, зосередьте увагу на результатах Редактора пошуку замість вводу Редактора пошуку.</target>
      </trans-unit>
      <trans-unit id="search.searchEditor.reusePriorSearchConfiguration">
        <source xml:lang="en">When enabled, new Search Editors will reuse the includes, excludes, and flags of the previously opened Search Editor.</source>
        <note>"Search Editor" is a type of editor that can display search results. "includes, excludes, and flags" refers to the "files to include" and "files to exclude" input boxes, and the flags that control whether a query is case-sensitive or a regex.</note>
        <target>Коли увімкнено, нові Редактори Пошуку повторно використовуватимуть includes, excludes та flags попередньо відкритого Редактора Пошуку.</target>
      </trans-unit>
      <trans-unit id="search.searchEditor.singleClickBehaviour">
        <source xml:lang="en">Configure effect of single-clicking a result in a search editor.</source>
        <target>Налаштуйте ефект одиничного клацання на результаті в редакторі пошуку.</target>
      </trans-unit>
      <trans-unit id="search.searchEditor.singleClickBehaviour.default">
        <source xml:lang="en">Single-clicking does nothing.</source>
        <target>Одноклікове натискання нічого не робить.</target>
      </trans-unit>
      <trans-unit id="search.searchEditor.singleClickBehaviour.peekDefinition">
        <source xml:lang="en">Single-clicking opens a Peek Definition window.</source>
        <target>Однокліком відкривається вікно Попереднього перегляду визначення.</target>
      </trans-unit>
      <trans-unit id="searchEditor">
        <source xml:lang="en">Search Editor</source>
        <target>Пошук</target>
      </trans-unit>
      <trans-unit id="searchEditor.action.decreaseSearchEditorContextLines">
        <source xml:lang="en">Decrease Context Lines</source>
        <target>Зменшити контекстні рядки</target>
      </trans-unit>
      <trans-unit id="searchEditor.action.increaseSearchEditorContextLines">
        <source xml:lang="en">Increase Context Lines</source>
        <target>Збільшити контекстні рядки</target>
      </trans-unit>
      <trans-unit id="searchEditor.action.selectAllSearchEditorMatches">
        <source xml:lang="en">Select All Matches</source>
        <target>Вибрати всі збіги</target>
      </trans-unit>
      <trans-unit id="searchEditor.action.toggleSearchEditorCaseSensitive">
        <source xml:lang="en">Toggle Match Case</source>
        <target>Перемикати регістр</target>
      </trans-unit>
      <trans-unit id="searchEditor.action.toggleSearchEditorContextLines">
        <source xml:lang="en">Toggle Context Lines</source>
        <target>Переключити контекстні рядки</target>
      </trans-unit>
      <trans-unit id="searchEditor.action.toggleSearchEditorRegex">
        <source xml:lang="en">Toggle Use Regular Expression</source>
        <target>Перемкнути Використовувати Регулярний Вираз</target>
      </trans-unit>
      <trans-unit id="searchEditor.action.toggleSearchEditorWholeWord">
        <source xml:lang="en">Toggle Match Whole Word</source>
        <target>Перемикати відповідність цілого слова</target>
      </trans-unit>
      <trans-unit id="searchEditor.deleteResultBlock">
        <source xml:lang="en">Delete File Results</source>
        <target>Видалити результати файлу</target>
      </trans-unit>
    </body>
  </file>
  <file original="src/vs/workbench/contrib/searchEditor/browser/searchEditorInput" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="searchEditorLabelIcon">
        <source xml:lang="en">Icon of the search editor label.</source>
        <target>Іконка мітки редактора пошуку.</target>
      </trans-unit>
      <trans-unit id="searchTitle">
        <source xml:lang="en">Search</source>
        <target>Пошук</target>
      </trans-unit>
      <trans-unit id="searchTitle.withQuery">
        <source xml:lang="en">Search: {0}</source>
        <target>Пошук: {0}</target>
      </trans-unit>
    </body>
  </file>
  <file original="src/vs/workbench/contrib/searchEditor/browser/searchEditorSerialization" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="invalidQueryStringError">
        <source xml:lang="en">All backslashes in Query string must be escaped (\\)</source>
        <target>Усі зворотні слеші в рядку запиту повинні бути екрановані (\\)</target>
      </trans-unit>
      <trans-unit id="noResults">
        <source xml:lang="en">No Results</source>
        <target>Немає результатів</target>
      </trans-unit>
      <trans-unit id="numFiles">
        <source xml:lang="en">{0} files</source>
        <target>{0} файлів</target>
      </trans-unit>
      <trans-unit id="numResults">
        <source xml:lang="en">{0} results</source>
        <target>{0} результати</target>
      </trans-unit>
      <trans-unit id="oneFile">
        <source xml:lang="en">1 file</source>
        <target>1 файл</target>
      </trans-unit>
      <trans-unit id="oneResult">
        <source xml:lang="en">1 result</source>
        <target>1 результат</target>
      </trans-unit>
      <trans-unit id="searchMaxResultsWarning">
        <source xml:lang="en">The result set only contains a subset of all matches. Be more specific in your search to narrow down the results.</source>
        <target>Набір результатів містить лише підмножину всіх збігів. Будьте більш конкретними у своєму пошуку, щоб звузити результати.</target>
      </trans-unit>
    </body>
  </file>
