  <file original="src/vs/workbench/contrib/welcomeOnboarding/browser/onboardingVariationA" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="onboarding.a.aria">
        <source xml:lang="en">Welcome to Visual Studio Code</source>
        <target>Ласкаво просимо до Visual Studio Code</target>
      </trans-unit>
      <trans-unit id="onboarding.aiPref.hint">
        <source xml:lang="en">You can change this anytime in Settings.</source>
        <target>Ви можете змінити це в будь-який час у Налаштуваннях.</target>
      </trans-unit>
      <trans-unit id="onboarding.aiPref.label">
        <source xml:lang="en">Choose your AI collaboration style</source>
        <target>Виберіть свій стиль співпраці з ШІ</target>
      </trans-unit>
      <trans-unit id="onboarding.aiPref.selected.alert">
        <source xml:lang="en">{0} selected</source>
        <target>{0} вибрано</target>
      </trans-unit>
      <trans-unit id="onboarding.back">
        <source xml:lang="en">Back</source>
        <target>Назад</target>
      </trans-unit>
      <trans-unit id="onboarding.close">
        <source xml:lang="en">Close</source>
        <target>Закрити</target>
      </trans-unit>
      <trans-unit id="onboarding.continueWithoutSignIn">
        <source xml:lang="en">Continue without Signing In</source>
        <target>Продовжити без входу в систему</target>
      </trans-unit>
      <trans-unit id="onboarding.getStarted">
        <source xml:lang="en">Get Started</source>
        <target>Почати</target>
      </trans-unit>
      <trans-unit id="onboarding.keymap.installError">
        <source xml:lang="en">Could not install {0} keymap. You can install it later from Extensions.</source>
        <target>Не вдалося встановити {0} розкладку клавіатури. Ви можете встановити її пізніше з Розширень.</target>
      </trans-unit>
      <trans-unit id="onboarding.keymap.selected.alert">
        <source xml:lang="en">{0} keyboard mapping selected</source>
        <target>Вибрано мапування клавіатури {0}</target>
      </trans-unit>
      <trans-unit id="onboarding.next">
        <source xml:lang="en">Continue</source>
        <target>Продовжити</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.keymap">
        <source xml:lang="en">Keyboard Mapping</source>
        <target>Картографування клавіатури</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.keymapHint">
        <source xml:lang="en">Coming from another editor? Import your keyboard mapping to feel right at home.</source>
        <target>Переходите з іншого редактора? Імпортуйте свою розкладку клавіатури, щоб відчувати себе як вдома.</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.keymapLabel">
        <source xml:lang="en">Choose a keyboard mapping</source>
        <target>Виберіть розкладку клавіатури</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.theme">
        <source xml:lang="en">Color Theme</source>
        <target>Тема кольору</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.themeHint">
        <source xml:lang="en">You can browse and install more themes later from the Extensions view.</source>
        <target>Ви можете переглядати та встановлювати більше тем пізніше з вигляду Розширення.</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.themeLabel">
        <source xml:lang="en">Choose a color theme</source>
        <target>Виберіть кольорову тему</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.tip.modifier">
        <source xml:lang="en">{0}</source>
        <note>This is a keyboard modifier key, Ctrl on Windows/Linux or Cmd on Mac</note>
        <target>Це клавіша-модифікатор клавіатури, Ctrl на Windows/Linux або Cmd на Mac {0}</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.tip.p">
        <source xml:lang="en">P</source>
        <target>P</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.tip.prefix">
        <source xml:lang="en">Tip: Press </source>
        <target>Порада: Натисніть</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.tip.shift">
        <source xml:lang="en">Shift</source>
        <target>Зміщення</target>
      </trans-unit>
      <trans-unit id="onboarding.personalize.tip.suffix">
        <source xml:lang="en"> to access all VS Code commands.</source>
        <target>щоб отримати доступ до всіх команд VS Code.</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.agentsTutorial">
        <source xml:lang="en">Agents tutorial</source>
        <target>Посібник для агентів</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.cloud">
        <source xml:lang="en">Cloud</source>
        <target>Хмара</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.cloud.desc">
        <source xml:lang="en">Delegate tasks to a cloud agent that creates a branch, implements changes, and opens a pull request. The agent continues working even if you close VS Code.</source>
        <target>Делегуйте завдання хмарному агенту, який створює гілку, впроваджує зміни та відкриває запит на злиття. Агент продовжує працювати, навіть якщо ви закриєте VS Code.</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.inline">
        <source xml:lang="en">Inline Suggestions</source>
        <target>Вбудовані пропозиції</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.inline.desc1">
        <source xml:lang="en">As you type, AI suggests completions and next edit predictions inline. Press </source>
        <target>Під час введення тексту ШІ пропонує завершення та прогнози наступних редагувань в рядку. Натисніть</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.inline.desc2">
        <source xml:lang="en"> to accept or </source>
        <target>прийняти або</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.inline.desc3">
        <source xml:lang="en"> to dismiss.</source>
        <target>звільнити.</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.inline.esc">
        <source xml:lang="en">Esc</source>
        <target>Esc</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.inline.tab">
        <source xml:lang="en">Tab</source>
        <target>Вкладка</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.local">
        <source xml:lang="en">Local</source>
        <target>Локальний</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.local.desc">
        <source xml:lang="en">Run agents interactively in the editor with full access to your workspace, tools, and terminal. Best for hands-on work where you want to review changes as they happen.</source>
        <target>Запускайте агенти інтерактивно в редакторі з повним доступом до вашого робочого простору, інструментів і терміналу. Найкраще для практичної роботи, де ви хочете переглядати зміни в реальному часі.</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.signInNudge">
        <source xml:lang="en">Sign in for AI Powered Features</source>
        <target>Увійдіть для отримання функцій на базі ШІ</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.worktree">
        <source xml:lang="en">Copilot CLI</source>
        <target>Copilot CLI</target>
      </trans-unit>
      <trans-unit id="onboarding.sessions.worktree.desc">
        <source xml:lang="en">Run agents autonomously in an isolated worktree on your machine. Work on something else while the agent builds, tests, and iterates in the background.</source>
        <target>Запускайте агенти автономно в ізольованому робочому дереві на вашій машині. Працюйте над чимось іншим, поки агент будує, тестує та ітеративно працює у фоновому режимі.</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.apple">
        <source xml:lang="en">Continue with Apple</source>
        <target>Продовжити з Apple</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.disclaimer.copilotPrefix">
        <source xml:lang="en">. {0} Copilot may show </source>
        <target>. {0} Copilot може показати</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.disclaimer.improveSuffix">
        <source xml:lang="en"> suggestions and use your data to improve the product.</source>
        <target>пропозиції та використовуйте ваші дані для покращення продукту.</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.disclaimer.middle">
        <source xml:lang="en"> and </source>
        <target>і</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.disclaimer.prefix">
        <source xml:lang="en">By signing in, you agree to {0}'s </source>
        <target>Увійшовши, ви погоджуєтеся з {0}</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.disclaimer.privacy">
        <source xml:lang="en">Privacy Statement</source>
        <target>Заява про конфіденційність</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.disclaimer.publicCode">
        <source xml:lang="en">public code</source>
        <target>публічний код</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.disclaimer.settings">
        <source xml:lang="en">settings</source>
        <target>налаштування</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.disclaimer.settingsPrefix">
        <source xml:lang="en">You can change these </source>
        <target>Ви можете змінити ці.</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.disclaimer.suffix">
        <source xml:lang="en"> anytime.</source>
        <target>в будь-який час.</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.disclaimer.terms">
        <source xml:lang="en">Terms</source>
        <target>Умови</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.enterprise.error">
        <source xml:lang="en">GitHub Enterprise sign-in failed. Check your instance URL and try again.</source>
        <target>Не вдалося увійти в GitHub Enterprise. Перевірте URL вашого екземпляра та спробуйте ще раз.</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.enterprise.invalid">
        <source xml:lang="en">You must enter a valid {0} instance (i.e. "octocat" or "https://octocat.ghe.com")</source>
        <target>Ви повинні ввести дійсний {0} екземпляр (тобто "octocat" або "https://octocat.ghe.com")</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.enterprise.placeholder">
        <source xml:lang="en">i.e. "octocat" or "https://octocat.ghe.com"...</source>
        <target>т.е. "octocat" або "https://octocat.ghe.com"...</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.enterprise.prompt">
        <source xml:lang="en">What is your {0} instance?</source>
        <target>Яка ваша {0} інстанція?</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.enterprise.resolve">
        <source xml:lang="en">Will resolve to {0}</source>
        <target>Вирішить до {0}</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.error">
        <source xml:lang="en">Sign-in failed. You can try again later from the Accounts menu.</source>
        <target>Не вдалося увійти. Ви можете спробувати ще раз пізніше з меню Облікові записи.</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.ghe">
        <source xml:lang="en">GHE</source>
        <target>GHE</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.ghe.aria">
        <source xml:lang="en">Continue with GitHub Enterprise</source>
        <target>Продовжити з GitHub Enterprise</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.github">
        <source xml:lang="en">Continue with GitHub</source>
        <target>Продовжити з GitHub</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.github.aria">
        <source xml:lang="en">Continue with GitHub</source>
        <target>Продовжити з GitHub</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.google">
        <source xml:lang="en">Continue with Google</source>
        <target>Продовжити з Google</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.heroSubtitle">
        <source xml:lang="en">Sign in to continue with AI-powered development.</source>
        <target>Увійдіть, щоб продовжити з розробкою на основі штучного інтелекту.</target>
      </trans-unit>
      <trans-unit id="onboarding.signIn.heroTitle">
        <source xml:lang="en">Welcome to VS Code</source>
        <target>Ласкаво просимо до VS Code</target>
      </trans-unit>
      <trans-unit id="onboarding.step.agentSessions.subtitle.after">
        <source xml:lang="en"> to open Chat</source>
        <target>відкрити Чат</target>
      </trans-unit>
      <trans-unit id="onboarding.step.agentSessions.subtitle.before">
        <source xml:lang="en">Tip: Press </source>
        <target>Порада: натисніть</target>
      </trans-unit>
      <trans-unit id="onboarding.step.aria">
        <source xml:lang="en">Step {0} of {1}: {2}</source>
        <target>Крок {0} з {1}: {2}</target>
      </trans-unit>
      <trans-unit id="onboarding.stepOf">
        <source xml:lang="en">{0} of {1}</source>
        <target>{0} з {1}</target>
      </trans-unit>
      <trans-unit id="onboarding.theme.selected.alert">
        <source xml:lang="en">{0} theme selected</source>
        <target>Вибрано тему {0}</target>
      </trans-unit>
    </body>
  </file>
