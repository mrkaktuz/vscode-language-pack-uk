  <file original="src/vs/workbench/contrib/welcomeOnboarding/common/onboardingTypes" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="onboarding.aiPref.agentForward">
        <source xml:lang="en">AI Takes the Lead</source>
        <target>ШІ бере на себе лідерство</target>
      </trans-unit>
      <trans-unit id="onboarding.aiPref.agentForward.desc">
        <source xml:lang="en">Let the agent drive — describe what you want and review the result. Great for scaffolding and exploration.</source>
        <target>Нехай агент керує — опишіть, що ви хочете, і перегляньте результат. Чудово підходить для структуризації та дослідження.</target>
      </trans-unit>
      <trans-unit id="onboarding.aiPref.balanced">
        <source xml:lang="en">Side by Side</source>
        <target>Пліч-о-пліч</target>
      </trans-unit>
      <trans-unit id="onboarding.aiPref.balanced.desc">
        <source xml:lang="en">Inline suggestions plus a chat panel for deeper collaboration. A balance of writing and delegating.</source>
        <target>Вбудовані пропозиції плюс панель чату для глибшої співпраці. Баланс між написанням і делегуванням.</target>
      </trans-unit>
      <trans-unit id="onboarding.aiPref.codeFirst">
        <source xml:lang="en">I Write the Code</source>
        <target>Я пишу код</target>
      </trans-unit>
      <trans-unit id="onboarding.aiPref.codeFirst.desc">
        <source xml:lang="en">AI assists with suggestions and answers questions when you ask. You stay in control of every edit.</source>
        <target>Штучний інтелект допомагає з пропозиціями та відповідає на запитання, коли ви запитуєте. Ви залишаєтеся під контролем кожного редагування.</target>
      </trans-unit>
      <trans-unit id="onboarding.step.agentSessions">
        <source xml:lang="en">Meet Your Agentic Coding Partner</source>
        <target>Зустрічайте свого агентного кодувального партнера</target>
      </trans-unit>
      <trans-unit id="onboarding.step.agentSessions.subtitle">
        <source xml:lang="en">Tip: Press {0} to open Chat</source>
        <target>Порада: натисніть {0}, щоб відкрити чат</target>
      </trans-unit>
      <trans-unit id="onboarding.step.aiPreference">
        <source xml:lang="en">Your AI Style</source>
        <target>Ваш стиль ШІ</target>
      </trans-unit>
      <trans-unit id="onboarding.step.aiPreference.subtitle">
        <source xml:lang="en">Choose how much AI collaboration fits your workflow</source>
        <target>Виберіть, наскільки співпраця з ШІ підходить вашому робочому процесу.</target>
      </trans-unit>
      <trans-unit id="onboarding.step.personalize">
        <source xml:lang="en">Make It Yours</source>
        <target>Зробіть це своїм</target>
      </trans-unit>
      <trans-unit id="onboarding.step.personalize.subtitle">
        <source xml:lang="en">Choose your theme and keyboard mapping</source>
        <target>Виберіть свою тему та розкладку клавіатури</target>
      </trans-unit>
      <trans-unit id="onboarding.step.signIn">
        <source xml:lang="en">Sign In</source>
        <target>Увійти</target>
      </trans-unit>
      <trans-unit id="onboarding.step.signIn.subtitle">
        <source xml:lang="en">Sync settings, unlock AI features, and connect to GitHub</source>
        <target>Налаштування синхронізації, розблокування функцій ШІ та підключення до GitHub</target>
      </trans-unit>
    </body>
  </file>
