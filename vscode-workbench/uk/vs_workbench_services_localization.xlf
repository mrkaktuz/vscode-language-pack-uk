<?xml version="1.0" encoding="utf-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
  <file original="src/vs/workbench/services/localization/electron-browser/localeService" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="argvInvalid">
        <source xml:lang="en">Unable to write display language. Please open the runtime settings, correct errors/warnings in it and try again.</source>
        <target>Неможливо записати мову відображення. Будь ласка, відкрийте налаштування виконання, виправте помилки/попередження в них і спробуйте ще раз.</target>
      </trans-unit>
      <trans-unit id="installing">
        <source xml:lang="en">Installing {0} language support...</source>
        <target>Встановлення підтримки мови {0}...</target>
      </trans-unit>
      <trans-unit id="openArgv">
        <source xml:lang="en">Open Runtime Settings</source>
        <target>Відкрити налаштування виконання</target>
      </trans-unit>
      <trans-unit id="restart">
        <source xml:lang="en">&amp;&amp;Restart</source>
        <note>&amp;&amp; denotes a mnemonic character</note>
        <target>&amp;&amp;Перезапустити</target>
      </trans-unit>
      <trans-unit id="restartDisplayLanguageDetail1">
        <source xml:lang="en">To change the display language to {0}, {1} needs to restart.</source>
        <target>Щоб змінити мову відображення на {0}, {1} потрібно перезапустити.</target>
      </trans-unit>
      <trans-unit id="restartDisplayLanguageMessage1">
        <source xml:lang="en">Restart {0} to switch to {1}?</source>
        <target>Перезапустити {0}, щоб перейти до {1}?</target>
      </trans-unit>
    </body>
  </file>
</xliff>