<?xml version="1.0" encoding="utf-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
  <file original="src/vs/workbench/contrib/imageCarousel/browser/imageCarousel.contribution" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="folderReadError">
        <source xml:lang="en">Could not read folder contents.</source>
        <target>Не вдалося прочитати вміст папки.</target>
      </trans-unit>
      <trans-unit id="imageCarousel.chat.enabled">
        <source xml:lang="en">Controls whether clicking an image attachment in chat opens the Images Preview viewer.</source>
        <target>Контролює, чи відкриває клік на вкладений зображення в чаті переглядач попереднього перегляду зображень.</target>
      </trans-unit>
      <trans-unit id="imageCarousel.explorerContextMenu.enabled">
        <source xml:lang="en">Controls whether the **Open in Images Preview** option appears in the Explorer context menu.</source>
        <target>Контролює, чи з'являється опція **Відкрити в переглядачі зображень** у контекстному меню Провідника.</target>
      </trans-unit>
      <trans-unit id="imageCarousel.explorerTitle">
        <source xml:lang="en">Images Preview</source>
        <target>Попередній перегляд зображень</target>
      </trans-unit>
      <trans-unit id="imageCarousel.title">
        <source xml:lang="en">Images Preview</source>
        <target>Попередній перегляд зображень</target>
      </trans-unit>
      <trans-unit id="imageCarouselConfigurationTitle">
        <source xml:lang="en">Images Preview</source>
        <target>Попередній перегляд зображень</target>
      </trans-unit>
      <trans-unit id="imageCarouselEditor">
        <source xml:lang="en">Images Preview</source>
        <target>Попередній перегляд зображень</target>
      </trans-unit>
      <trans-unit id="noImagesFound">
        <source xml:lang="en">No images found in this folder.</source>
        <target>У цій папці не знайдено зображень.</target>
      </trans-unit>
      <trans-unit id="openImageInCarousel">
        <source xml:lang="en">Open in Images Preview</source>
        <target>Відкрити в переглядачі зображень</target>
      </trans-unit>
      <trans-unit id="openImagesInCarousel">
        <source xml:lang="en">Open in Images Preview</source>
        <target>Відкрити в перегляді зображень</target>
      </trans-unit>
    </body>
  </file>
  <file original="src/vs/workbench/contrib/imageCarousel/browser/imageCarouselEditor" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="imageCarousel.ariaLabel">
        <source xml:lang="en">Images Preview</source>
        <target>Попередній перегляд зображень</target>
      </trans-unit>
      <trans-unit id="imageCarousel.counter">
        <source xml:lang="en">{0} / {1}</source>
        <target>{0} / {1}</target>
      </trans-unit>
      <trans-unit id="imageCarousel.kindImage">
        <source xml:lang="en">Image</source>
        <target>Зображення</target>
      </trans-unit>
      <trans-unit id="imageCarousel.kindVideo">
        <source xml:lang="en">Video</source>
        <target>Відео</target>
      </trans-unit>
      <trans-unit id="imageCarousel.nextImage">
        <source xml:lang="en">Next image</source>
        <target>Наступне зображення</target>
      </trans-unit>
      <trans-unit id="imageCarousel.noImages">
        <source xml:lang="en">No images to display</source>
        <target>Немає зображень для відображення</target>
      </trans-unit>
      <trans-unit id="imageCarousel.previousImage">
        <source xml:lang="en">Previous image</source>
        <target>Попереднє зображення</target>
      </trans-unit>
      <trans-unit id="imageCarousel.statusWithCaption">
        <source xml:lang="en">{0} {1} of {2}: {3}</source>
        <target>{0} {1} з {2}: {3}</target>
      </trans-unit>
      <trans-unit id="imageCarousel.statusWithName">
        <source xml:lang="en">{0} {1} of {2}: {3}</source>
        <target>{0} {1} з {2}: {3}</target>
      </trans-unit>
      <trans-unit id="imageCarousel.thumbnailLabelImage">
        <source xml:lang="en">Image {0} of {1}</source>
        <target>Зображення {0} з {1}</target>
      </trans-unit>
      <trans-unit id="imageCarousel.thumbnailLabelVideo">
        <source xml:lang="en">Video {0} of {1}</source>
        <target>Відео {0} з {1}</target>
      </trans-unit>
      <trans-unit id="imageCarousel.thumbnails">
        <source xml:lang="en">Image thumbnails</source>
        <target>Зображення ескізів</target>
      </trans-unit>
    </body>
  </file>
</xliff>