<?xml version="1.0" encoding="utf-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
  <file original="src/vs/workbench/contrib/meteredConnection/browser/meteredConnection.contribution" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="configureMeteredConnection">
        <source xml:lang="en">Configure Metered Connection</source>
        <target>Налаштувати обмежене з'єднання</target>
      </trans-unit>
      <trans-unit id="meteredConnection.auto">
        <source xml:lang="en">Auto</source>
        <target>Авто</target>
      </trans-unit>
      <trans-unit id="meteredConnection.auto.description">
        <source xml:lang="en">Detect metered connections automatically</source>
        <target>Автоматично виявляти обмежені з'єднання</target>
      </trans-unit>
      <trans-unit id="meteredConnection.off">
        <source xml:lang="en">Off</source>
        <target>Вимкнено</target>
      </trans-unit>
      <trans-unit id="meteredConnection.off.description">
        <source xml:lang="en">Never treat the connection as metered</source>
        <target>Ніколи не розглядайте з'єднання як обмежене.</target>
      </trans-unit>
      <trans-unit id="meteredConnection.on">
        <source xml:lang="en">On</source>
        <target>На</target>
      </trans-unit>
      <trans-unit id="meteredConnection.on.description">
        <source xml:lang="en">Always treat the connection as metered</source>
        <target>Завжди вважайте з'єднання платним.</target>
      </trans-unit>
      <trans-unit id="meteredConnection.placeholder">
        <source xml:lang="en">Select Metered Connection Mode</source>
        <target>Виберіть режим підключення з обмеженням трафіку</target>
      </trans-unit>
    </body>
  </file>
  <file original="src/vs/workbench/contrib/meteredConnection/browser/meteredConnectionStatus" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="status.meteredConnection">
        <source xml:lang="en">Metered Connection</source>
        <target>Обмежене з'єднання</target>
      </trans-unit>
      <trans-unit id="status.meteredConnection.ariaLabel">
        <source xml:lang="en">Metered Connection Enabled</source>
        <target>Увімкнено обмежене з'єднання</target>
      </trans-unit>
      <trans-unit id="status.meteredConnection.configure">
        <source xml:lang="en">Configure</source>
        <target>Налаштувати</target>
      </trans-unit>
      <trans-unit id="status.meteredConnection.tooltip">
        <source xml:lang="en">Metered connection enabled. Some automatic features like extension updates, Settings Sync, and automatic Git operations are paused to reduce data usage.</source>
        <target>Увімкнено підключення з обмеженням трафіку. Деякі автоматичні функції, такі як оновлення розширень, синхронізація налаштувань та автоматичні операції Git, призупинені для зменшення використання даних.</target>
      </trans-unit>
    </body>
  </file>
