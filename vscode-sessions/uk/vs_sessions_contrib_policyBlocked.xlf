<?xml version="1.0" encoding="utf-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
  <file original="src/vs/sessions/contrib/policyBlocked/browser/sessionsPolicyBlocked" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="accountGate.approvedOrgs">
        <source xml:lang="en">Approved organizations:</source>
        <target>Схвалені організації:</target>
      </trans-unit>
      <trans-unit id="accountGate.aria">
        <source xml:lang="en">Sign-in required by organization policy</source>
        <target>Необхідний вхід відповідно до політики організації</target>
      </trans-unit>
      <trans-unit id="accountGate.contactAdmin">
        <source xml:lang="en">Contact your administrator for more information.</source>
        <target>Зв'яжіться з вашим адміністратором для отримання додаткової інформації.</target>
      </trans-unit>
      <trans-unit id="accountGate.descriptionNoAccount">
        <source xml:lang="en">Sign in with a GitHub account from an approved organization to use Agents.</source>
        <target>Увійдіть за допомогою облікового запису GitHub з затвердженої організації, щоб використовувати Агенти.</target>
      </trans-unit>
      <trans-unit id="accountGate.descriptionWithAccount">
        <source xml:lang="en">The account "{0}" is not a member of an approved organization. Sign into an approved GitHub account to use Agents.</source>
        <target>Обліковий запис "{0}" не є членом затвердженої організації. Увійдіть в затверджений обліковий запис GitHub, щоб використовувати Агентів.</target>
      </trans-unit>
      <trans-unit id="accountGate.learnMore">
        <source xml:lang="en">Learn more</source>
        <target>Дізнатися більше</target>
      </trans-unit>
      <trans-unit id="accountGate.signIn">
        <source xml:lang="en">Sign In</source>
        <target>Увійти</target>
      </trans-unit>
      <trans-unit id="accountGate.title">
        <source xml:lang="en">Sign-In Required</source>
        <target>Необхідна авторизація</target>
      </trans-unit>
      <trans-unit id="loading.aria">
        <source xml:lang="en">Loading</source>
        <target>Завантаження</target>
      </trans-unit>
      <trans-unit id="policyBlocked.aria">
        <source xml:lang="en">Agents disabled by organization policy</source>
        <target>Агенти вимкнені політикою організації</target>
      </trans-unit>
      <trans-unit id="policyBlocked.description">
        <source xml:lang="en">Your organization has disabled Agents via policy.</source>
        <target>Ваша організація вимкнула агентів через політику.</target>
      </trans-unit>
      <trans-unit id="policyBlocked.learnMore">
        <source xml:lang="en">Learn more</source>
        <target>Дізнатися більше</target>
      </trans-unit>
      <trans-unit id="policyBlocked.openVSCode">
        <source xml:lang="en">Open VS Code</source>
        <target>Відкрити VS Code</target>
      </trans-unit>
      <trans-unit id="policyBlocked.title">
        <source xml:lang="en">Agents Disabled</source>
        <target>Агенти вимкнені</target>
      </trans-unit>
    </body>
  </file>
