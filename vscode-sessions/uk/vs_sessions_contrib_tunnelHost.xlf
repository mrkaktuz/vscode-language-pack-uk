<?xml version="1.0" encoding="utf-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
  <file original="src/vs/sessions/contrib/tunnelHost/electron-browser/toggleRemoteConnectionsActionViewItem" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="tunnelHost.hover.connecting">
        <source xml:lang="en">Establishing tunnel connection...</source>
        <target>Встановлення тунельного з'єднання...</target>
      </trans-unit>
      <trans-unit id="tunnelHost.hover.enabled">
        <source xml:lang="en">Remote session access is enabled</source>
        <target>Доступ до віддаленої сесії увімкнено</target>
      </trans-unit>
      <trans-unit id="tunnelHost.hover.idle">
        <source xml:lang="en">Allow remote session access</source>
        <target>Дозволити доступ до віддаленої сесії</target>
      </trans-unit>
      <trans-unit id="tunnelHost.hover.sharing">
        <source xml:lang="en">Remote session access enabled via tunnel '{0}'</source>
        <target>Доступ до віддаленої сесії увімкнено через тунель '{0}'</target>
      </trans-unit>
      <trans-unit id="tunnelHost.hover.showOutput">
        <source xml:lang="en">Show Output</source>
        <target>Показати вихідні дані</target>
      </trans-unit>
      <trans-unit id="tunnelHost.toast">
        <source xml:lang="en">Remote session access is now enabled</source>
        <target>Доступ до віддаленої сесії тепер увімкнено.</target>
      </trans-unit>
    </body>
  </file>
  <file original="src/vs/sessions/contrib/tunnelHost/electron-browser/tunnelHost.contribution" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="showTunnelHostOutput">
        <source xml:lang="en">Show Remote Connections Output</source>
        <target>Показати вихід віддалених з'єднань</target>
      </trans-unit>
      <trans-unit id="toggleSharing">
        <source xml:lang="en">Allow Remote Connections</source>
        <target>Дозволити віддалені з'єднання</target>
      </trans-unit>
      <trans-unit id="tunnelHost.category">
        <source xml:lang="en">Remote Connections</source>
        <target>Віддалені з'єднання</target>
      </trans-unit>
      <trans-unit id="tunnelHost.enableMicrosoftAuth">
        <source xml:lang="en">Enable Microsoft account authentication for agent host tunnels. When disabled, only GitHub authentication is used.</source>
        <target>Увімкніть аутентифікацію облікового запису Microsoft для тунелів хоста агента. Коли вимкнено, використовується лише аутентифікація GitHub.</target>
      </trans-unit>
      <trans-unit id="tunnelHost.error">
        <source xml:lang="en">Failed to toggle remote connections: {0}</source>
        <target>Не вдалося перемкнути віддалені з'єднання: {0}</target>
      </trans-unit>
    </body>
  </file>
  <file original="src/vs/sessions/contrib/tunnelHost/electron-browser/tunnelHostService" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="tunnelHost.noAuth">
        <source xml:lang="en">No authentication token available. Please sign in and try again.</source>
        <target>Немає доступного токена автентифікації. Будь ласка, увійдіть у систему та спробуйте ще раз.</target>
      </trans-unit>
      <trans-unit id="tunnelHost.outputChannel">
        <source xml:lang="en">Remote Connections</source>
        <target>Віддалені з'єднання</target>
      </trans-unit>
    </body>
  </file>
</xliff>