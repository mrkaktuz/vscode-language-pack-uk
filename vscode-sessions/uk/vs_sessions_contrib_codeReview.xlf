<?xml version="1.0" encoding="utf-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
  <file original="src/vs/sessions/contrib/codeReview/browser/codeReview.contributions" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="sessions.canRunCodeReview">
        <source xml:lang="en">True when a new code review can be started for the active session version.</source>
        <target>Істина, коли можна розпочати новий код-рев'ю для активної версії сесії.</target>
      </trans-unit>
      <trans-unit id="sessions.runCodeReview">
        <source xml:lang="en">Run Code Review</source>
        <target>Запустити перевірку коду</target>
      </trans-unit>
      <trans-unit id="sessions.runCodeReview.noChanges">
        <source xml:lang="en">No changes available for code review.</source>
        <target>Немає змін, доступних для перегляду коду.</target>
      </trans-unit>
      <trans-unit id="sessions.runCodeReview.noSession">
        <source xml:lang="en">No active session available for code review.</source>
        <target>Немає активної сесії для перегляду коду.</target>
      </trans-unit>
      <trans-unit id="sessions.runCodeReview.tooltip.default">
        <source xml:lang="en">Run Code Review</source>
        <target>Запустити перевірку коду</target>
      </trans-unit>
      <trans-unit id="sessions.runCodeReview.tooltip.limitReached">
        <source xml:lang="en">Maximum of {0} code reviews reached for this session version.</source>
        <target>Досягнуто максимального значення {0} кодових рев'ю для цієї версії сесії.</target>
      </trans-unit>
      <trans-unit id="sessions.runCodeReview.tooltip.loading">
        <source xml:lang="en">Creating code review...</source>
        <target>Створення огляду коду...</target>
      </trans-unit>
      <trans-unit id="sessions.runCodeReview.tooltip.manyUnresolved">
        <source xml:lang="en">{0} review comments unresolved.</source>
        <target>{0} коментарів до огляду не вирішено.</target>
      </trans-unit>
      <trans-unit id="sessions.runCodeReview.tooltip.noCommentsRunAgain">
        <source xml:lang="en">Previous code review produced no comments. Run code review again.</source>
        <target>Попередній перегляд коду не дав жодних коментарів. Запустіть перегляд коду знову.</target>
      </trans-unit>
      <trans-unit id="sessions.runCodeReview.tooltip.oneUnresolved">
        <source xml:lang="en">1 review comment unresolved.</source>
        <target>1 коментар до відгуку не вирішено.</target>
      </trans-unit>
      <trans-unit id="sessions.runCodeReview.tooltip.runAgain">
        <source xml:lang="en">Run another code review.</source>
        <target>Запустіть ще один код-рев'ю.</target>
      </trans-unit>
    </body>
  </file>
</xliff>