  <file original="src/vs/sessions/contrib/welcome/browser/sessionsWalkthrough" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="walkthrough.aria">
        <source xml:lang="en">Agents onboarding walkthrough</source>
        <target>Посібник з інтеграції агентів</target>
      </trans-unit>
      <trans-unit id="walkthrough.canceledError">
        <source xml:lang="en">Sign-in was canceled. Please try again.</source>
        <target>Увійти не вдалося. Будь ласка, спробуйте ще раз.</target>
      </trans-unit>
      <trans-unit id="walkthrough.disclaimer.end">
        <source xml:lang="en"> anytime.</source>
        <target>в будь-який час.</target>
      </trans-unit>
      <trans-unit id="walkthrough.disclaimer.final">
        <source xml:lang="en"> suggestions and use your data to improve the product. You can change these </source>
        <target>пропозиції та використовуйте свої дані для покращення продукту. Ви можете змінити ці</target>
      </trans-unit>
      <trans-unit id="walkthrough.disclaimer.middle">
        <source xml:lang="en"> and </source>
        <target>і</target>
      </trans-unit>
      <trans-unit id="walkthrough.disclaimer.prefix">
        <source xml:lang="en">By continuing, you agree to GitHub's </source>
        <target>Продовжуючи, ви погоджуєтеся з умовами GitHub's</target>
      </trans-unit>
      <trans-unit id="walkthrough.disclaimer.privacy">
        <source xml:lang="en">Privacy Statement</source>
        <target>Заява про конфіденційність</target>
      </trans-unit>
      <trans-unit id="walkthrough.disclaimer.publicCode">
        <source xml:lang="en">public code</source>
        <target>публічний код</target>
      </trans-unit>
      <trans-unit id="walkthrough.disclaimer.settings">
        <source xml:lang="en">settings</source>
        <target>налаштування</target>
      </trans-unit>
      <trans-unit id="walkthrough.disclaimer.suffix">
        <source xml:lang="en">. GitHub Copilot may show </source>
        <target>. GitHub Copilot може показувати</target>
      </trans-unit>
      <trans-unit id="walkthrough.disclaimer.terms">
        <source xml:lang="en">Terms</source>
        <target>Умови</target>
      </trans-unit>
      <trans-unit id="walkthrough.finishingSubtitle">
        <source xml:lang="en">Getting everything ready for you.</source>
        <target>Готуємо все для вас.</target>
      </trans-unit>
      <trans-unit id="walkthrough.poweredBy">
        <source xml:lang="en">Complete authorization in your browser.</source>
        <target>Завершіть авторизацію у вашому браузері.</target>
      </trans-unit>
      <trans-unit id="walkthrough.restart">
        <source xml:lang="en">Completing Agents setup</source>
        <target>Завершення налаштування агентів</target>
      </trans-unit>
      <trans-unit id="walkthrough.settingUp">
        <source xml:lang="en">Signing in…</source>
        <target>Увійти…</target>
      </trans-unit>
      <trans-unit id="walkthrough.signInError">
        <source xml:lang="en">Something went wrong. Please try again.</source>
        <target>Щось пішло не так. Будь ласка, спробуйте ще раз.</target>
      </trans-unit>
      <trans-unit id="walkthrough.signin.apple">
        <source xml:lang="en">Continue with Apple</source>
        <target>Продовжити з Apple</target>
      </trans-unit>
      <trans-unit id="walkthrough.signin.enterprise">
        <source xml:lang="en">Continue with {0}</source>
        <target>Продовжити з {0}</target>
      </trans-unit>
      <trans-unit id="walkthrough.signin.github">
        <source xml:lang="en">Continue with GitHub</source>
        <target>Продовжити з GitHub</target>
      </trans-unit>
      <trans-unit id="walkthrough.signin.google">
        <source xml:lang="en">Continue with Google</source>
        <target>Продовжити з Google</target>
      </trans-unit>
      <trans-unit id="walkthrough.signingIn">
        <source xml:lang="en">Finishing setup…</source>
        <target>Завершення налаштування…</target>
      </trans-unit>
      <trans-unit id="walkthrough.step1.subtitle">
        <source xml:lang="en">Sign in to continue with agent-powered development.</source>
        <target>Увійдіть, щоб продовжити з розробкою за допомогою агентів.</target>
      </trans-unit>
      <trans-unit id="walkthrough.step1.title">
        <source xml:lang="en">Welcome to Agents</source>
        <target>Ласкаво просимо до Агентів</target>
      </trans-unit>
    </body>
  </file>
