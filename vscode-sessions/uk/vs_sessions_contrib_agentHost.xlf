  <file original="src/vs/sessions/contrib/agentHost/browser/agentSessionSettingsFileSystemProvider" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="agentSessionSettings.header">
        <source xml:lang="en">Session settings for this agent host session.</source>
        <target>Налаштування сеансу для цього сеансу хоста агента.</target>
      </trans-unit>
      <trans-unit id="agentSessionSettings.notObject">
        <source xml:lang="en">Agent session settings must be a JSON object.</source>
        <target>Налаштування сесії агента повинні бути об'єктом JSON.</target>
      </trans-unit>
      <trans-unit id="agentSessionSettings.parseError">
        <source xml:lang="en">Failed to parse agent session settings as JSON.</source>
        <target>Не вдалося розібрати налаштування сесії агента як JSON.</target>
      </trans-unit>
      <trans-unit id="agentSessionSettings.saveHint">
        <source xml:lang="en">Edit values below and save to apply. Unknown or non-mutable properties are ignored.</source>
        <target>Редагуйте значення нижче та збережіть, щоб застосувати. Невідомі або незмінні властивості ігноруються.</target>
      </trans-unit>
    </body>
  </file>
