  <file original="src/vs/sessions/contrib/agentHost/browser/agentHostSettingsFileSystemProvider" source-language="en" datatype="plaintext" target-language="uk">
    <body>
      <trans-unit id="agentHostSettings.header">
        <source xml:lang="en">Agent host settings.</source>
        <target>Налаштування хоста агента.</target>
      </trans-unit>
      <trans-unit id="agentHostSettings.notObject">
        <source xml:lang="en">Agent host settings must be a JSON object.</source>
        <target>Налаштування хоста агента повинні бути об'єктом JSON.</target>
      </trans-unit>
      <trans-unit id="agentHostSettings.parseError">
        <source xml:lang="en">Failed to parse agent host settings as JSON.</source>
        <target>Не вдалося розпарсити налаштування хоста агента як JSON.</target>
      </trans-unit>
      <trans-unit id="agentHostSettings.saveHint">
        <source xml:lang="en">Edit values below and save to apply. Unknown properties are ignored.</source>
        <target>Редагуйте значення нижче та збережіть, щоб застосувати. Невідомі властивості ігноруються.</target>
      </trans-unit>
    </body>
  </file>
