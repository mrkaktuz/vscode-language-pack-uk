      <trans-unit id="agentSessions.runSkill.createPR">
        <source xml:lang="en">Create Pull Request</source>
        <target>Створити Pull Request</target>
      </trans-unit>
      <trans-unit id="agentSessions.runSkill.merge">
        <source xml:lang="en">Merge Changes</source>
        <target>Об'єднати зміни</target>
      </trans-unit>
      <trans-unit id="agentSessions.runSkill.updatePR">
        <source xml:lang="en">Sync Pull Request</source>
        <target>Синхронізувати запит на злиття</target>
      </trans-unit>
    </body>
  </file>
